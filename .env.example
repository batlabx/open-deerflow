# Copy to .env and adjust. Every value has a sensible local default.

# --- Models (Ollama) -------------------------------------------------------
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
REASONING_MODEL=qwen2.5:14b-instruct
BASIC_MODEL=llama3.1:8b-instruct
LLM_TEMPERATURE=0.2

# --- Search ----------------------------------------------------------------
# Self-hosted SearxNG (see docker-compose.yml). If it is unreachable the search
# tool automatically falls back to the keyless DuckDuckGo backend.
SEARXNG_URL=http://localhost:8080
MAX_SEARCH_RESULTS=6

# --- Sandbox ---------------------------------------------------------------
SANDBOX_IMAGE=python:3.12-slim
SANDBOX_TIMEOUT_S=20

# --- Graph -----------------------------------------------------------------
MAX_PLAN_STEPS=6
CHECKPOINT_DB=checkpoints.sqlite
